# Copy this file to ".env" and fill in real values.
# The real ".env" is gitignored and must NEVER be committed.

# SQL Server connection (Windows auth used, so no DB user/password needed)
DB_SERVER=YOUR_SERVER\SQLEXPRESS
DB_DATABASE=EmpAssetDB

# JWT signing key. Generate a fresh random one, e.g. in PowerShell:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be long and secret. Do NOT reuse the example value.
SECRET_KEY=replace-with-a-long-random-secret
